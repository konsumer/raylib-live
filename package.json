{
  "name": "raylib-live",
  "private": true,
  "version": "0.0.0",
  "description": "live-reloading raylib project template",
  "scripts": {
    "build:native": "cmake -B build -DCMAKE_BUILD_TYPE=Release && cmake --build build",
    "build:web": "emcmake cmake -B wbuild -DPLATFORM=Web -DCMAKE_BUILD_TYPE=Release && cmake --build wbuild ",
    "build:web:reload": "npx -y nodemon -w ./src -i wbuild -e c,cpp,html -x 'npm run build:web'",
    "dev:web": "npx -y live-server wbuild --entry-file=my_raylib_game.html --ignore=_deps,CMakeFiles",
    "start": "npx -y npm-run-all --parallel dev:web build:web:reload",
    "start:docker": "docker build --no-cache -t konsumer/raylib-live . && docker run --rm -it -p 8080:8080 -v .:/work konsumer/raylib-live"
  },
  "keywords": [],
  "author": "David Konsumer <konsumer@jetboystudio.com>",
  "license": "MIT"
}
